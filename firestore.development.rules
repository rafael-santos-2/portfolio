rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------------------------------
    // HELPERS
    // ------------------------------------------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(id_user) {
      return request.auth.uid == id_user;
    }

    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isDeveloper() {
      return hasRole('Developer');
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    function hasValidCreateAudit() {
      return request.resource.data.id_creator == request.auth.uid
        && request.resource.data.keys().hasAll(['date_created', 'id_creator']);
    }

    function hasValidUpdateAudit() {
      return request.resource.data.id_updater == request.auth.uid
        && request.resource.data.keys().hasAll(['date_updated', 'id_updater']);
    }

    function hasValidSoftDeleteAudit() {
      return request.resource.data.id_deleter == request.auth.uid
        && request.resource.data.is_deleted == true
        && request.resource.data.keys().hasAll(['is_deleted', 'date_deleted', 'id_deleter']);
    }

    function hasValidDisableAudit() {
      return request.resource.data.id_disabler == request.auth.uid
        && request.resource.data.is_disabled == true
        && request.resource.data.keys().hasAll(['is_disabled', 'date_disabled', 'id_disabler']);
    }

    function isSoftDelete() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasAll(['is_deleted', 'date_deleted', 'id_deleter'])
        && changedKeys.hasOnly(['is_deleted', 'date_deleted', 'id_deleter']);
    }

    function isDisable() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasAll(['is_disabled', 'date_disabled'])
        && changedKeys.hasOnly(['is_disabled', 'date_disabled', 'date_updated', 'id_updater']);
    }


    // ------------------------------------------------------------------------------------------------
    // USERS
    // ------------------------------------------------------------------------------------------------
    match /users/{id_user} {
      allow read, write: if isDeveloper();

      allow create: if false;

      allow read: if isAdmin() || (isAuthenticated() && isOwner(id_user));

      allow update: if isAdmin() && (
          (isDisable() && hasValidDisableAudit())
          || (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['email', 'firstName', 'lastName', 'fullname', 'role', 'type', 'path_avatar', 'date_updated', 'id_updater'])
            && hasValidUpdateAudit())
        );

      allow update: if isAuthenticated() && isOwner(id_user)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['email', 'firstName', 'lastName', 'fullname', 'path_avatar', 'last_seen_version', 'date_updated', 'id_updater'])
        && hasValidUpdateAudit();

      allow delete: if false;
    }

    match /users/{id_user}/fcm_tokens/{id_token} {
      allow read, write: if isAuthenticated() && isOwner(id_user);
    }

    match /users/{id_user}/notifications/{id_notification} {
      allow read, write: if isDeveloper();

      allow create: if false;

      allow read: if isAuthenticated() && isOwner(id_user);

      allow update: if isAuthenticated() && isOwner(id_user)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['is_read', 'date_read', 'is_archived', 'date_archived', 'date_updated', 'id_updater']);

      allow delete: if isAuthenticated() && isOwner(id_user);
    }


    // ------------------------------------------------------------------------------------------------
    // MEMBERS
    // ------------------------------------------------------------------------------------------------
    match /members/{id_member} {
      allow read, write: if isDeveloper();

      allow create: if isAdmin() && hasValidCreateAudit();

      allow read: if isAuthenticated();

      allow update: if isAdmin() && (
          (isSoftDelete() && hasValidSoftDeleteAudit())
          || hasValidUpdateAudit()
        );

      allow delete: if false;
    }


    // ------------------------------------------------------------------------------------------------
    // MAINTENANCE
    // ------------------------------------------------------------------------------------------------
    match /maintenance/{id_maintenance} {
      allow read, write: if isDeveloper();

      allow create: if isAdmin() && hasValidCreateAudit();

      allow read: if isAuthenticated();

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['title', 'message', 'scheduled_start', 'scheduled_end', 'is_active', 'date_updated', 'id_updater'])
        && hasValidUpdateAudit();

      allow delete: if isAdmin();
    }


    // ------------------------------------------------------------------------------------------------
    // PROCESSES
    // ------------------------------------------------------------------------------------------------
    match /processes/{id_process} {
      allow read, write: if isDeveloper();

      allow create: if isAuthenticated()
        && request.resource.data.id_initiator == request.auth.uid;

      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.id_initiator == request.auth.uid);

      allow update: if isAdmin()
        || (isAuthenticated() && resource.data.id_initiator == request.auth.uid);

      allow delete: if isAdmin()
        || (isAuthenticated() && resource.data.id_initiator == request.auth.uid);
    }

    match /processes/{id_process}/actions/{id_action} {
      allow read, write: if isDeveloper();

      allow create, update: if isAdmin()
        || (isAuthenticated()
            && get(/databases/$(database)/documents/processes/$(id_process)).data.id_initiator == request.auth.uid);

      allow read: if isAdmin()
        || (isAuthenticated()
            && get(/databases/$(database)/documents/processes/$(id_process)).data.id_initiator == request.auth.uid);

      allow delete: if isAdmin();
    }


    // ------------------------------------------------------------------------------------------------
    // LOGS
    // ------------------------------------------------------------------------------------------------
    match /logs/{id_log} {
      allow read, write: if isDeveloper();

      allow create: if isAuthenticated();

      allow read: if isAdmin();

      allow update, delete: if false;
    }


    // ------------------------------------------------------------------------------------------------
    // DEFAULT
    // ------------------------------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
