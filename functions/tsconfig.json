{
  "compilerOptions": {
    "module": "NodeNext",
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "paths": {
      "@/types/*": ["../types/*"],
      "@/database/*": ["../database/*"]
    }
  },
  "compileOnSave": true,
  "include": [
    "index.ts",
    "calls/**/*",
    "config/**/*",
    "jobs/**/*",
    "triggers/**/*",
    "types/**/*",
    "utils/**/*",
    "../database/**/*.type.ts",
    "../types/firestore.type.ts"
  ]
}
