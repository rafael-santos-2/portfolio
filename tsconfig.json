{
  "compilerOptions": {
    "target": "es2024",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/css/*": [
        "./css/*"
      ],
      "@/navigations/*": [
        "./navigations/*"
      ],
      "@/providers": [
        "./providers/index.ts"
      ],
      "@/providers/*": [
        "./providers/*"
      ],
      "@/components": [
        "./components/index.ts"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/widgets/*": [
        "./widgets/*"
      ],
      "@/views/*": [
        "./views/*"
      ],
      "@/guards": [
        "./guards/index.ts"
      ],
      "@/guards/*": [
        "./guards/*"
      ],
      "@/sections/*": [
        "./sections/*"
      ],
      "@/hooks/*": [
        "./hooks/*"
      ],
      "@/languages/*": [
        "./languages/*"
      ],
      "@/config/*": [
        "./config/*"
      ],
      "@/utils/*": [
        "./utils/*"
      ],
      "@/database": [
        "./database/index.ts"
      ],
      "@/database/*": [
        "./database/*"
      ],
      "@/resources/*": [
        "./resources/*"
      ],
      "@/types": [
        "./types/index.ts"
      ],
      "@/types/*": [
        "./types/*"
      ],
      "@/layouts/*": [
        "./layouts/*"
      ],
      "@/data/*": [
        "./data/*"
      ],
      "@/pdf/*": [
        "./pdfs/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "scripts",
    "functions"
  ]
}
